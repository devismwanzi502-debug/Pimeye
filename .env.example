# Environment Variables Configuration
# Copy this file to .env and fill in your API keys

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# Server Configuration
PORT=10000

# API Keys (Optional - for enhanced reverse image search)
# Get these from the respective platforms to enable full API integration

# Google Cloud Vision API
# Documentation: https://cloud.google.com/vision/docs
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# TinEye API
# Documentation: https://api.tineye.com/
TINEYE_API_KEY=your-tineye-api-key

# Microsoft Azure Computer Vision
# Documentation: https://learn.microsoft.com/en-us/azure/ai-services/computer-vision/
AZURE_VISION_KEY=your-azure-vision-key
AZURE_VISION_ENDPOINT=your-azure-endpoint

# Bing Visual Search API
# Documentation: https://learn.microsoft.com/en-us/bing/search-apis/bing-visual-search/overview
BING_VISUAL_SEARCH_KEY=your-bing-visual-search-key

# Social Media APIs (for platform-specific searches)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# Database Configuration (for storing search history)
DATABASE_URL=sqlite:///pimeye.db

# Logging
LOG_LEVEL=INFO
